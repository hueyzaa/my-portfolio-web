{
  "name": "web_react_boilerplate",
  "private": true,
  "version": "1.0.0",
  "description": "REACT BOILERPLATE By MF9",
  "author": "mf9team",
  "license": "UNLICENSED",
  "scripts": {
    "prepare": "test -d node_modules/husky && husky install || echo \"husky is not installed\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "dev": "yarn buildThemes && vite --host --mode development",
    "build": "yarn buildThemes && rimraf ./dist && tsc && vite build",
    "build:staging": "yarn buildThemes && rimraf ./dist && tsc && vite build --mode staging",
    "build:production": "yarn buildThemes && rimraf ./dist && tsc && vite build --mode production",
    "preview": "vite preview",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:fix": "eslint --fix --ext ts,tsx src/",
    "prettier": "prettier --check \"src/**/(*.tsx|*.ts|*.css|*.scss)\"",
    "prettier:fix": "prettier --write \"src/**/(*.tsx|*.ts|*.css|*.scss)\"",
    "buildThemes": "lessc --js --clean-css=\"--s1 --advanced\" src/styles/themes/main.less public/main.css"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@reduxjs/toolkit": "^2.5.1",
    "@types/react-google-recaptcha": "^2.1.9",
    "antd": "^4.24.16",
    "antd-img-crop": "^4.24.0",
    "axios": "^1.7.9",
    "axios-mock-adapter": "^2.1.0",
    "chart.js": "^4.4.7",
    "chartjs-plugin-datalabels": "^2.2.0",
    "country-list": "^2.3.0",
    "crypto-js": "^4.2.0",
    "i18next": "^25.7.4",
    "js-file-download": "^0.4.12",
    "lodash": "^4.17.21",
    "lucide-react": "^0.562.0",
    "moment": "^2.30.1",
    "platform": "^1.3.6",
    "query-string": "^9.1.1",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-country-flag": "^3.1.0",
    "react-dom": "^18.3.1",
    "react-export-table-to-excel": "^1.0.6",
    "react-google-recaptcha": "^3.1.0",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^15.7.4",
    "react-icons": "^5.4.0",
    "react-phone-number-input": "^3.4.11",
    "react-quill": "^2.0.0",
    "react-redux": "^9.2.0",
    "react-responsive": "^10.0.0",
    "react-router-dom": "6.3.0",
    "react-spreadsheet": "^0.9.5",
    "react-to-print": "^3.0.5",
    "react-verification-input": "^4.2.0",
    "rimraf": "^5.0.10",
    "styled-components": "^6.1.15",
    "uuid": "^11.0.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.7.1",
    "@eslint/js": "^9.19.0",
    "@types/country-list": "^2.1.4",
    "@types/crypto-js": "^4.2.2",
    "@types/history": "^4.7.11",
    "@types/lodash": "^4.17.15",
    "@types/node": "^22.19.5",
    "@types/platform": "^1.3.6",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/react-redux": "^7.1.34",
    "@types/react-router-dom": "^5.3.3",
    "@types/styled-components": "^5.1.36",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
